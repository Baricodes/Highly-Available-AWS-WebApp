# Terraform — local state and working directory (never commit)
.terraform/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
crash.log
crash.*.log

# Variable files often contain secrets
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Local CLI config
.terraformrc
terraform.rc

# Saved plans
*.tfplan

# Local overrides (not for shared modules)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Commit .terraform.lock.hcl for consistent provider versions

# Secrets and keys
*.pem
.env
.env.*

# OS
.DS_Store
